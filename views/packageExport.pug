doctype html
html
	head
		title Table with Checkboxes
		style.
			body {
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				height: 100vh;
				font-family: Arial, sans-serif;
			}
			table {
				border-collapse: collapse;
				margin: 0 auto;
				width: 60%;
				text-align: center;
			}
			th, td {
				border: 1px solid #ddd;
				padding: 8px;
			}
			th {
				background-color: #f2f2f2;
			}
			button {
				margin-top: 20px;
				padding: 10px 20px;
				background-color: #4CAF50;
				color: white;
				border: none;
				cursor: pointer;
			}
			button:hover {
				background-color: #45a049;
			}

			form {
				width : 100%;
			}

			.error-message {
				color: red;
				margin-bottom: 10px;
			}

			.permision-set-box {
				margin-top: 20px;
				display: flex;
				justify-content: center;
			}

			#selectAll {
				cursor: pointer;
			}
	body
		.error-message= errorMessage
		form(action="/generatePackageXml" method="post" id="packageXmlForm") 
			table(name="tables" id="tables")
				thead
					tr
						th
							input(type="checkbox", id="selectAll")
						//- th Schema Name
						th Table Name
						th Number Of Columns
						th Size
				tbody
					each val in tables
						tr
							td
								input(type="checkbox"
									,name= "selectedTables"
									,value= val.tablename 
									,checked= (selectedTables && selectedTables.includes(val.tablename) || null)
									,class="table-checkbox"
								)

							//- td #{val.schemaname}
							td #{val.tablename}
							td #{val.number_of_columns}
							td #{val.table_size}
			.permision-set-box
				input(type="checkbox", id="includePermissonSet" name="includePermissonSet" checked)
				label(for="includePermissonSet") Include Permission Set 
			//- Centering the button under the table
		button(type="submit" form="packageXmlForm") Get package.xml

		script.
			document.addEventListener('DOMContentLoaded', function() {
				const selectAllCheckbox = document.getElementById('selectAll');
				const tableCheckboxes = document.querySelectorAll('.table-checkbox');

				// Handle select all checkbox change
				selectAllCheckbox.addEventListener('change', function() {
					const isChecked = this.checked;
					tableCheckboxes.forEach(function(checkbox) {
						checkbox.checked = isChecked;
					});
				});

				// Handle individual checkbox changes to update select all state
				tableCheckboxes.forEach(function(checkbox) {
					checkbox.addEventListener('change', function() {
						updateSelectAllState();
					});
				});

				// Function to update the "select all" checkbox state
				function updateSelectAllState() {
					const checkedCount = document.querySelectorAll('.table-checkbox:checked').length;
					const totalCount = tableCheckboxes.length;
					
					if (checkedCount === 0) {
						selectAllCheckbox.checked = false;
						selectAllCheckbox.indeterminate = false;
					} else if (checkedCount === totalCount) {
						selectAllCheckbox.checked = true;
						selectAllCheckbox.indeterminate = false;
					} else {
						selectAllCheckbox.checked = false;
						selectAllCheckbox.indeterminate = true;
					}
				}

				// Initialize the select all state on page load
				updateSelectAllState();
			});
